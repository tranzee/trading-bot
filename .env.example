# ============================================================================
# polybot — environment template
# Copy to .env (NEVER commit .env). All values shown are safe defaults or
# documented placeholders.
# ============================================================================

# === Polymarket V2 ========================================================
# Wallet that holds the trading bankroll. Use a wallet that ONLY holds the
# bankroll — top up from a cold wallet. Never reuse keys with high-value funds.
POLYMARKET_PRIVATE_KEY=0xREPLACE_WITH_YOUR_PRIVATE_KEY
# Proxy/funder address from polymarket.com -> Settings (the address that holds pUSD).
POLYMARKET_FUNDER_ADDRESS=0xREPLACE_WITH_YOUR_FUNDER_ADDRESS
# Optional: builder code from your Builder Profile (V2 native; no HMAC headers).
POLYMARKET_BUILDER_CODE=
# POLYMARKET_HOST
#   Pre-April-28-2026: https://clob-v2.polymarket.com (testnet)
#   On/after April 28 ~11:00 UTC: https://clob.polymarket.com (production V2 takes over)
#   Same SDK (py-clob-client-v2), same code path — only this URL changes at cutover.
POLYMARKET_HOST=https://clob-v2.polymarket.com

# === Polygon RPC ==========================================================
POLYGON_RPC_URL=https://polygon-rpc.com
# Optional fallback RPC (different provider) for failover.
POLYGON_RPC_URL_FALLBACK=

# === Modes ================================================================
# paper | live | backtest. Default to paper. Live requires explicit operator action.
RUN_MODE=paper
LOG_LEVEL=INFO

# === Risk caps (USD) ======================================================
WALLET_BALANCE=100.0
MAX_SESSION_LOSS=10.0
MAX_DAILY_LOSS=20.0
MAX_PER_TRADE_USD=5.0
MAX_PER_TRADE_FRACTION=0.05
CONSECUTIVE_LOSS_LIMIT=5

# === Truth layer (BTC data) ===============================================
BTC_SOURCES=binance,coinbase,chainlink
DIVERGENCE_THRESHOLD_BPS=50
SOURCE_STALE_TIMEOUT_S=5

# === Strategy ============================================================
STRATEGY=price_action_maker
MIN_SIGNAL_CONFIDENCE=0.55
MAKER_DISCOUNT_TICKS=1
CANCEL_REPLACE_MS=200
EXIT_BEFORE_CLOSE_S=30

# === Force flags (NEVER commit values that bypass safety) =================
# Bypass interactive Y/N prompt before going live. Leave false in production.
FORCE_LIVE=false
# NEVER set to true in production. Only for local debugging of version checks.
SKIP_VERSION_CHECK=false
